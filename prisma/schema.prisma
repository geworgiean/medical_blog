model Post {
  id        String   @id @default(uuid())
  title     String
  content   String
  category  String  @default("Ընդհանուր")
  published Boolean  @default(false)
  createdAt DateTime @default(now())
  comments  Comment[]
}

model Comment {
  id        String   @id @default(uuid())
  content   String
  author    String   @default("Անանուն")
  createdAt DateTime @default(now())

  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
}